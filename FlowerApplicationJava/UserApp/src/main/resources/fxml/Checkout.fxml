<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="flowershop.controllers.OrderController"
            stylesheets="@../css/user-style.css"
            style="-fx-background-color: #f8eef1;">

    <top>
        <HBox prefHeight="56.0" alignment="CENTER_LEFT" spacing="22.0" style="-fx-background-color: #f7c8d7;">
            <padding>
                <Insets top="0.0" right="18.0" bottom="0.0" left="18.0"/>
            </padding>
            <children>
                <Label text="Flower shop"
                       style="-fx-text-fill: #8e5f5f; -fx-font-size: 24px; -fx-font-weight: 500;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Home" onAction="#goHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 18px;"/>
                <Button text="Flowers" onAction="#goFlowers"
                        style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 18px;"/>
                <Button text="Categories" onAction="#goCategories"
                        style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 18px;"/>
                <Button text="Contact" onAction="#goContact"
                        style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 18px;"/>
                <Button text="Cart" onAction="#goCart"
                        style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 18px; -fx-underline: true;"/>
                <Button text="Log Out" onAction="#handleLogout"
                        prefWidth="94.0" prefHeight="34.0"
                        style="-fx-background-color: #f59bc0; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 700; -fx-background-radius: 6;"/>
            </children>
        </HBox>
    </top>

    <center>
        <StackPane style="-fx-background-color: #f8eef1;">
            <children>
                <VBox spacing="28.0" maxWidth="1260.0" prefWidth="1260.0">
                    <padding>
                        <Insets top="26.0" right="30.0" bottom="26.0" left="30.0"/>
                    </padding>

                    <children>

                        <Label text="Checkout"
                               maxWidth="1260.0"
                               prefHeight="42.0"
                               style="-fx-background-color: #edd6d8; -fx-text-fill: #8e5f5f; -fx-font-size: 20px; -fx-font-weight: 700; -fx-padding: 8 0 0 16;"/>

                        <HBox spacing="80.0">
                            <children>

                                <VBox spacing="20.0" prefWidth="520.0">
                                    <children>
                                        <Label text="Customer Information"
                                               style="-fx-text-fill: #8e5f5f; -fx-font-size: 20px; -fx-font-weight: 700;"/>

                                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                                            <children>
                                                <Label text="Full name" prefWidth="100.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;"/>
                                                <TextField prefWidth="250.0" style="-fx-background-color: #f6d6e0;"/>
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                                            <children>
                                                <Label text="Email" prefWidth="100.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;"/>
                                                <TextField prefWidth="250.0" style="-fx-background-color: #f6d6e0;"/>
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                                            <children>
                                                <Label text="Phone" prefWidth="100.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;"/>
                                                <TextField prefWidth="250.0" style="-fx-background-color: #f6d6e0;"/>
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                                            <children>
                                                <Label text="Address" prefWidth="100.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;"/>
                                                <TextField prefWidth="250.0" style="-fx-background-color: #f6d6e0;"/>
                                            </children>
                                        </HBox>

                                        <VBox spacing="10.0">
                                            <children>
                                                <Label text="Payment Method"
                                                       style="-fx-text-fill: #8e5f5f; -fx-font-size: 20px; -fx-font-weight: 700;"/>
                                                <CheckBox text="Credit Card"/>
                                                <CheckBox text="PayPal"/>
                                                <CheckBox text="Cash on Delivery"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <Region prefWidth="1.5" maxHeight="340.0" style="-fx-background-color: #f59bc0;"/>

                                <VBox spacing="18.0" prefWidth="350.0">
                                    <children>
                                        <Label text="Order Summary"
                                               style="-fx-text-fill: #8e5f5f; -fx-font-size: 20px; -fx-font-weight: 700;"/>
                                        <Label text="--------------"
                                               style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px;"/>

                                        <HBox>
                                            <children>
                                                <Label text="Rose Bouquet x1" prefWidth="220.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"/>
                                                <Label text="\$25" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"/>
                                            </children>
                                        </HBox>

                                        <HBox>
                                            <children>
                                                <Label text="Tulip Bouquet x1" prefWidth="220.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"/>
                                                <Label text="\$25" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"/>
                                            </children>
                                        </HBox>

                                        <Region prefHeight="14.0"/>

                                        <HBox>
                                            <children>
                                                <Label text="Subtotal" prefWidth="220.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"/>
                                                <Label text="\$50" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"/>
                                            </children>
                                        </HBox>

                                        <HBox>
                                            <children>
                                                <Label text="Shipping" prefWidth="220.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"/>
                                                <Label text="\$5" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"/>
                                            </children>
                                        </HBox>

                                        <HBox>
                                            <children>
                                                <Label text="Total" prefWidth="220.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"/>
                                                <Label text="\$55" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"/>
                                            </children>
                                        </HBox>

                                        <Button text="Place Order"
                                                prefWidth="180.0" prefHeight="48.0"
                                                style="-fx-background-color: #f59bc0; -fx-text-fill: #8e5f5f; -fx-font-size: 24px; -fx-background-radius: 6;"/>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="36.0" style="-fx-background-color: #f7c8d7;">
            <children>
                <Label text="Flower Shop. flowershop@gmail.com"
                       style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>