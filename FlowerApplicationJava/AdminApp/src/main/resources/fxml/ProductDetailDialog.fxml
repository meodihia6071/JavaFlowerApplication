<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="overlayRoot" style="-fx-background-color: transparent; -fx-padding: 30;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.ProductDetailDialogController">

    <children>
        <BorderPane fx:id="dialogCard" maxWidth="920.0" prefHeight="520.0" prefWidth="920.0" style="-fx-background-color: #fff7f9;                            -fx-background-radius: 18;                            -fx-border-color: #f1c9d4;                            -fx-border-width: 1;                            -fx-border-radius: 18;                            -fx-padding: 24;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 20, 0.2, 0, 8);">

            <top>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnClose" onAction="#handleClose" style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 22px; -fx-font-weight: bold; -fx-cursor: hand;" text="✕" />
                    </children>
                </HBox>
            </top>

            <center>
                <HBox spacing="30.0">
                    <children>

                        <VBox alignment="CENTER" prefWidth="360.0" spacing="18.0">
                            <children>
                                <ImageView fx:id="imgProduct" fitHeight="300.0" fitWidth="300.0" preserveRatio="false" />
                                <Label fx:id="lblStock"
                                       style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;"
                                       text="Stock: 0" />
                                <Label fx:id="lblPrice" style="-fx-text-fill: #cf4f84; -fx-font-size: 34px; -fx-font-weight: 800;" text="\$0" />
                            </children>
                        </VBox>

                        <VBox prefWidth="460.0" spacing="20.0">
                            <children>
                                <Label fx:id="lblName" style="-fx-text-fill: #8e5f5f; -fx-font-size: 28px; -fx-font-weight: 800;" text="Product name" wrapText="true" />

                                <VBox spacing="10.0">
                                    <children>
                                        <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px; -fx-font-weight: 700;" text="Quantity" />

                                        <HBox fx:id="quantityBox" alignment="CENTER_LEFT" maxWidth="180.0" prefWidth="180.0" spacing="12.0" style="-fx-background-color: #f3dfe3; -fx-background-radius: 10; -fx-padding: 10 14 10 14;">
                                            <children>
                                                <Button fx:id="btnDecrease" onAction="#handleDecrease" style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 22px; -fx-font-weight: bold; -fx-cursor: hand;" text="-" />
                                                <Label fx:id="lblQuantity" alignment="CENTER" minWidth="45.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 22px; -fx-font-weight: 700;" text="1" />
                                                <Button fx:id="btnIncrease" onAction="#handleIncrease" style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 22px; -fx-font-weight: bold; -fx-cursor: hand;" text="+" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="10.0">
                                    <children>
                                        <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px; -fx-font-weight: 700;" text="Note" />
                                        <TextArea fx:id="txtNote" prefRowCount="5" promptText="Enter your note here..." style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #f1c9d4; -fx-border-radius: 10; -fx-text-fill: #8e5f5f; -fx-font-size: 15px;" wrapText="true" />
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                                    <children>
                                        <Button fx:id="btnCancel" onAction="#handleClose" style="-fx-background-color: #f1d7df; -fx-text-fill: #8e5f5f; -fx-font-size: 16px; -fx-font-weight: 700; -fx-background-radius: 8; -fx-cursor: hand;" text="Cancel" />
                                        <Button fx:id="btnAddToCart" onAction="#handleAddToCart" style="-fx-font-size: 18px;" styleClass="primary-button" text="Add to Cart" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </center>
        </BorderPane>
    </children>
</StackPane>
