<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #F8F8F8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.AdminProductsController">
    <children>
        <VBox prefWidth="220.0" style="-fx-background-color: #F6E1E5;">
            <children>
                <Label text="Flower shop" textFill="#613b41">
                    <font>
                        <Font name="System Bold" size="26.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" left="20.0" top="30.0" />
                    </VBox.margin>
                </Label>

                <Region prefHeight="1.0" style="-fx-background-color: #613b41;">
                    <VBox.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" />
                    </VBox.margin>
                </Region>

                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#goDashboard" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #613b41;" text="Dashboard">
                    <font><Font name="System Bold" size="16.0" /></font>
                    <padding><Insets left="30.0" /></padding>
                </Button>

                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #E5738B;" text="Products">
                    <font><Font name="System Bold" size="16.0" /></font>
                    <padding><Insets left="30.0" /></padding>
                </Button>

                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#goCategories" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #613b41;" text="Categories">
                    <font><Font name="System Bold" size="16.0" /></font>
                    <padding><Insets left="30.0" /></padding>
                </Button>

                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#goOrders" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #613b41;" text="Orders">
                    <font><Font name="System Bold" size="16.0" /></font>
                    <padding><Insets left="30.0" /></padding>
                </Button>

                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#goCustomers" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #613b41;" text="Customers">
                    <font><Font name="System Bold" size="16.0" /></font>
                    <padding><Insets left="30.0" /></padding>
                </Button>

                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#goSuppliers" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #613b41;" text="Suppliers">
                    <font><Font name="System Bold" size="16.0" /></font>
                    <padding><Insets left="30.0" /></padding>
                </Button>

                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#goStock" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #613b41;" text="Stock">
                    <font><Font name="System Bold" size="16.0" /></font>
                    <padding><Insets left="30.0" /></padding>
                </Button>

                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#goReports" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #613b41;" text="Reports">
                    <font><Font name="System Bold" size="16.0" /></font>
                    <padding><Insets left="30.0" /></padding>
                </Button>

                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#goUserManage" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-text-fill: #613b41;" text="User Manage">
                    <font><Font name="System Bold" size="16.0" /></font>
                    <padding><Insets left="30.0" /></padding>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Region prefHeight="1.0" style="-fx-background-color: #613b41;">
                    <VBox.margin><Insets bottom="20.0" left="20.0" right="20.0" /></VBox.margin>
                </Region>

                <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #FF99B8; -fx-text-fill: white; -fx-background-radius: 8;" text="&lt;- Log Out">
                    <VBox.margin>
                        <Insets bottom="30.0" left="30.0" />
                    </VBox.margin>
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
            </children>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="20.0" style="-fx-background-color: #FFFDFD;">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                <Label text="Products" textFill="#c95b74">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>

                <HBox spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" style="-fx-background-color: #F6DCE2; -fx-text-fill: #613b41; -fx-background-radius: 5;" text="+ Add Products">
                            <font><Font name="System Bold" size="14.0" /></font>
                            <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                        </Button>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" style="-fx-background-color: #F6DCE2; -fx-text-fill: #613b41; -fx-background-radius: 5;" text="Sort by &lt; &gt;">
                            <font><Font name="System Bold" size="14.0" /></font>
                            <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                        </Button>
                    </children>
                </HBox>

                <TableView VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #F6DCE2;">
                    <columns>
                        <TableColumn prefWidth="120.0" text="Image" />
                        <TableColumn prefWidth="150.0" text="Product Name" />
                        <TableColumn prefWidth="120.0" text="Category" />
                        <TableColumn prefWidth="80.0" text="Price" />
                        <TableColumn prefWidth="80.0" text="Stock" />
                        <TableColumn prefWidth="150.0" text="Action" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</HBox>