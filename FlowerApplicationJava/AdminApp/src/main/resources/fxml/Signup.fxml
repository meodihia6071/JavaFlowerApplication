<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane style="-fx-background-color: #f2f2f2;" stylesheets="@../css/user-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.AuthController">

    <children>
        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <HBox style="-fx-background-color: #f8eef1;">

                <children>

                    <VBox alignment="CENTER" prefWidth="500.0" spacing="30.0" style="-fx-background-color: #f8eef1;" translateX="100.0">
                        <children>

                            <VBox alignment="CENTER" spacing="10.0">
                                <children>
                                    <Label style="-fx-text-fill: #cf4f84; -fx-font-size: 32px; -fx-font-weight: 800;" text="Welcome to Flower Shop!" />
                                    <Label style="-fx-text-fill: #f07ea6; -fx-font-size: 18px; -fx-font-weight: 700;" text="Fresh Flowers For Every Moment" />
                                </children>
                            </VBox>

                            <GridPane hgap="16.0" maxWidth="380.0" vgap="14.0">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="90.0" prefWidth="105.0" />
                                    <ColumnConstraints hgrow="ALWAYS" minWidth="180.0" />
                                </columnConstraints>

                                <children>

                                    <!-- Last name -->
                                    <Label text="Last name" GridPane.columnIndex="0" GridPane.rowIndex="0"
                                           style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px;" />
                                    <TextField fx:id="txtLastName" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                               prefHeight="38.0"
                                               style="-fx-background-color: #f6d6e0; -fx-text-fill: #8e5f5f; -fx-font-size: 16px;" />

                                    <!-- First name -->
                                    <Label text="First name" GridPane.columnIndex="0" GridPane.rowIndex="1"
                                           style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px;" />
                                    <TextField fx:id="txtFirstName" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                               prefHeight="38.0"
                                               style="-fx-background-color: #f6d6e0; -fx-text-fill: #8e5f5f; -fx-font-size: 16px;" />

                                    <!-- Username -->
                                    <Label text="Username" GridPane.columnIndex="0" GridPane.rowIndex="2"
                                           style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px;" />
                                    <TextField fx:id="txtSignupUsername" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                               prefHeight="38.0"
                                               style="-fx-background-color: #f6d6e0; -fx-text-fill: #8e5f5f; -fx-font-size: 16px;" />

                                    <!-- Email -->
                                    <Label text="Email" GridPane.columnIndex="0" GridPane.rowIndex="3"
                                           style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px;" />
                                    <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="3"
                                               prefHeight="38.0"
                                               style="-fx-background-color: #f6d6e0; -fx-text-fill: #8e5f5f; -fx-font-size: 16px;" />

                                    <!-- Password -->
                                    <Label text="Password" GridPane.columnIndex="0" GridPane.rowIndex="4"
                                           style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px;" />
                                    <PasswordField fx:id="txtSignupPassword" GridPane.columnIndex="1" GridPane.rowIndex="4"
                                                   prefHeight="38.0"
                                                   style="-fx-background-color: #f6d6e0; -fx-text-fill: #8e5f5f; -fx-font-size: 16px;" />

                                    <!-- Confirm -->
                                    <Label text="Confirm" GridPane.columnIndex="0" GridPane.rowIndex="5"
                                           style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px;" />
                                    <PasswordField fx:id="txtConfirmPassword" GridPane.columnIndex="1" GridPane.rowIndex="5"
                                                   prefHeight="38.0"
                                                   style="-fx-background-color: #f6d6e0; -fx-text-fill: #8e5f5f; -fx-font-size: 16px;" />

                                </children>
                        <rowConstraints>
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                           <RowConstraints />
                            <RowConstraints />
                        </rowConstraints>
                            </GridPane>

                            <VBox alignment="CENTER" spacing="16.0">
                                <children>
                                    <Button onAction="#handleSignup" prefHeight="42.0" prefWidth="130.0" style="-fx-font-size: 20px;" styleClass="primary-button" text="Sign up" />

                                    <Label onMouseClicked="#goToLogin" style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px; -fx-font-weight: 700; -fx-cursor: hand;" text="Cancel" />
                                </children>
                            </VBox>

                        </children>
                        <padding>
                            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                        </padding>
                    </VBox>

                    <StackPane HBox.hgrow="ALWAYS">
                        <children>
                            <ImageView fitHeight="1000.0" fitWidth="820.0" preserveRatio="false" StackPane.alignment="CENTER_RIGHT">
                                <image>
                                    <Image url="@../images/login-bg.jpg" />
                                </image>
                            </ImageView>
                        </children>
                    </StackPane>

                </children>
            </HBox>
        </StackPane>
    </children>
</AnchorPane>
