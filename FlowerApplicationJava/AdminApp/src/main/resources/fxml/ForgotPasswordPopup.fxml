<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" style="-fx-background-color: #f8eef1; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="flowershop.controllers.ForgotPasswordController"
      prefWidth="450" prefHeight="450">

    <Label text="Reset Password" style="-fx-text-fill: #cf4f84; -fx-font-size: 26px; -fx-font-weight: bold;"/>

    <VBox fx:id="stepEmail" spacing="15" alignment="CENTER">
        <Label text="Vui lòng nhập Email đã đăng ký" style="-fx-text-fill: #8e5f5f;"/>
        <TextField fx:id="txtResetEmail" promptText="Email" prefHeight="40.0" maxWidth="300"
                   style="-fx-background-color: #f6d6e0; -fx-border-color: transparent;"/>
        <Button text="Gửi mã OTP" onAction="#handleSendOTP" prefHeight="40" prefWidth="150"
                styleClass="primary-button" style="-fx-background-color: #cf4f84; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </VBox>

    <VBox fx:id="stepOTP" spacing="15" alignment="CENTER" managed="false" visible="false">
        <Label text="Nhập mã 6 số đã được gửi tới Email của bạn" style="-fx-text-fill: #8e5f5f;"/>
        <TextField fx:id="txtOTP" promptText="------" alignment="CENTER" prefHeight="45.0" maxWidth="150"
                   style="-fx-background-color: #f6d6e0; -fx-font-size: 20px; -fx-letter-spacing: 10px;"/>

        <Label fx:id="lblTimer" text="Hết hạn sau: 02:00" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-font-size: 14px;"/>

        <HBox spacing="15" alignment="CENTER">
            <Button text="Xác nhận" onAction="#handleVerifyOTP" prefHeight="40" prefWidth="120"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button fx:id="btnResend" text="Gửi lại mã" onAction="#handleResendOTP" disable="true" prefHeight="40" prefWidth="120"
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <VBox fx:id="stepNewPass" spacing="15" alignment="CENTER" managed="false" visible="false">
        <Label text="Nhập mật khẩu mới của bạn" style="-fx-text-fill: #8e5f5f;"/>

        <HBox alignment="CENTER" spacing="5.0" maxWidth="330">
            <StackPane alignment="CENTER_LEFT">
                <PasswordField fx:id="txtNewPass" promptText="Mật khẩu mới" prefHeight="40.0" prefWidth="300" style="-fx-background-color: #f6d6e0;"/>
                <TextField fx:id="txtNewPassVisible" visible="false" managed="false" promptText="Mật khẩu mới" prefHeight="40.0" prefWidth="300" style="-fx-background-color: #f6d6e0;"/>
            </StackPane>
            <Button onAction="#toggleNewPassword" text="👁" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px; -fx-text-fill: #8e5f5f;" />
        </HBox>

        <HBox alignment="CENTER" spacing="5.0" maxWidth="330">
            <StackPane alignment="CENTER_LEFT">
                <PasswordField fx:id="txtConfirmNewPass" promptText="Xác nhận mật khẩu" prefHeight="40.0" prefWidth="300" style="-fx-background-color: #f6d6e0;"/>
                <TextField fx:id="txtConfirmNewPassVisible" visible="false" managed="false" promptText="Xác nhận mật khẩu" prefHeight="40.0" prefWidth="300" style="-fx-background-color: #f6d6e0;"/>
            </StackPane>
            <Button onAction="#toggleConfirmPassword" text="👁" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px; -fx-text-fill: #8e5f5f;" />
        </HBox>

        <Button text="Lưu mật khẩu" onAction="#handleResetPassword" prefHeight="40" prefWidth="150"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </VBox>

    <Label fx:id="lblMessage" style="-fx-text-fill: #e74c3c; -fx-font-size: 14px; -fx-font-weight: bold;" wrapText="true" alignment="CENTER"/>
</VBox>