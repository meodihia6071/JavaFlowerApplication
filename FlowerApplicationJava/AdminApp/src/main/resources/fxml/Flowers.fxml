<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f8eef1;" stylesheets="@../css/user-style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.FlowersController">

    <top>
        <HBox prefHeight="56.0"
              alignment="CENTER_LEFT"
              spacing="22.0"
              styleClass="top-bar">
            <padding>
                <Insets top="0.0" right="18.0" bottom="0.0" left="18.0"/>
            </padding>
            <children>
                <Label style="-fx-font-weight: 700; -fx-font-size: 25px;" text="Flower shop" styleClass="brand-label"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Home" onAction="#goHome" styleClass="nav-button"/>
                <Button text="Flowers" onAction="#goFlowers" styleClass="nav-button-active"/>
                <Button text="Categories" onAction="#goCategories" styleClass="nav-button"/>
                <Button text="Contact" onAction="#goContact" styleClass="nav-button"/>
                <Button fx:id="btnCart" text="Cart" onAction="#goCart" styleClass="nav-button"/>

                <Button text="Log Out" onAction="#handleLogout"
                        prefWidth="94.0" prefHeight="34.0"
                        styleClass="logout-button"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="10"
              style="-fx-background-color: #f8eef1;">


            <!-- SEARCH + FILTER (scroll) -->
            <ScrollPane fitToWidth="true"
                        vbarPolicy="AS_NEEDED"
                        style="-fx-background: #f8eef1; -fx-background-color: #f8eef1;"
                        VBox.vgrow="ALWAYS">

                <content>
                    <VBox alignment="TOP_CENTER" spacing="20">
                        <padding>
                            <Insets bottom="18" left="30" right="18" top="18"/>
                        </padding>

                        <HBox maxWidth="1280" spacing="30">
                            <VBox alignment="TOP_CENTER" spacing="18" HBox.hgrow="ALWAYS">

                                <TextField fx:id="txtSearch"
                                           maxWidth="980"
                                           prefHeight="42"
                                           promptText="Search flowers ..."
                                           style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-font-size: 18px;" />

                            </VBox>
                        </HBox>

                        <!-- PRODUCT -->
                        <TilePane fx:id="productTilePane"
                                  alignment="CENTER"
                                  hgap="30"
                                  vgap="28"
                                  prefColumns="4"
                                  prefTileHeight="280"
                                  prefTileWidth="190"/>

                    </VBox>
                </content>
            </ScrollPane>

            <!-- PAGINATION LUÔN Ở DƯỚI -->
            <HBox alignment="CENTER"
                  spacing="10"
                  styleClass="pagination-box">
                <padding>
                    <Insets top="0" right="0" bottom="40" left="0"/>
                </padding>

                <Button fx:id="btnPrev"
                        text="Prev"
                        onAction="#handlePrevPage"
                        styleClass="primary-button"/>

                <Label fx:id="lblPage"
                       text="Page 1"
                       styleClass="pagination-label"/>

                <Button fx:id="btnNext"
                        text="Next"
                        onAction="#handleNextPage"
                        styleClass="primary-button"/>

            </HBox>

        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER" prefHeight="36.0" style="-fx-background-color: #f7c8d7;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 13px;" text="Flower Shop. flowershop@gmail.com" />
            </children>
        </HBox>
    </bottom>
   <left>
       <VBox prefWidth="230.0" spacing="40.0" style="-fx-background-color: #f3dfe3; -fx-padding: 14;" BorderPane.alignment="CENTER">
                  <children>
                      <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 24px; -fx-font-weight: 700;" text="Flowers" />

                                        <VBox spacing="8.0">
                          <children>
                              <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Price range" />
                              <ComboBox fx:id="cboPriceRange" prefWidth="160.0" />
                          </children>
                      </VBox>

                      <VBox spacing="6.0">
                          <children>
                              <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Category filter" />
                              <CheckBox fx:id="chkFresh" text="Hoa Tươi" />
                              <CheckBox fx:id="chkBirthday" text="Hoa Sinh Nhật" />
                              <CheckBox fx:id="chkWedding" text="Hoa Cưới" />
                              <CheckBox fx:id="chkFormal" text="Hoa Trang Trọng" />
                          </children>
                      </VBox>

                                        <VBox spacing="6.0">
                          <children>
                              <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Availability" />
                              <CheckBox fx:id="chkInStockOnly" text="In stock only" />
                          </children>
                      </VBox>

                                        <VBox spacing="8.0">
                          <children>
                              <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Sort by:" />
                              <ComboBox fx:id="cboSortBy" prefWidth="160.0" />
                          </children>
                      </VBox>

                      <Button onAction="#handleShowResults" prefHeight="34.0" prefWidth="140.0" style="-fx-font-size: 14px;" styleClass="primary-button" text="Show results" />
                  </children>
              </VBox>
   </left>

</BorderPane>
