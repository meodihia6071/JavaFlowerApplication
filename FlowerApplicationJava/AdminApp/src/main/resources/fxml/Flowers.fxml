<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f8eef1;" stylesheets="@../css/user-style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.FlowersController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="56.0" spacing="22.0" styleClass="top-bar">
            <padding>
                <Insets bottom="0.0" left="18.0" right="18.0" top="0.0" />
            </padding>
            <children>
                <Label style="-fx-font-weight: 700; -fx-font-size: 27px;" styleClass="brand-label" text="Flower shop" />

                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#goHome" styleClass="nav-button" text="Home" />
                <Button onAction="#goFlowers" styleClass="nav-button-active" text="Flowers" />
                <Button onAction="#goCategories" styleClass="nav-button" text="Categories" />
                <Button onAction="#goContact" styleClass="nav-button" text="Contact" />
                <Button fx:id="btnCart" onAction="#goCart" styleClass="nav-button" text="Cart" />

                <Button fx:id="btnProfile" onAction="#goProfile" prefHeight="42.0" prefWidth="42.0" styleClass="nav-button">
                    <graphic>
                        <ImageView fitHeight="22.0" fitWidth="22.0" preserveRatio="true">
                            <image>
                                <Image url="@../images/user-icon.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#handleLogout" prefHeight="34.0" prefWidth="94.0" styleClass="logout-button" text="Log Out" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-background-color: #f8eef1;">


            <ScrollPane fitToWidth="true" style="-fx-background: #f8eef1; -fx-background-color: #f8eef1;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">

                <content>
                    <VBox alignment="TOP_CENTER" spacing="20">
                        <padding>
                            <Insets bottom="18" left="30" right="18" top="18" />
                        </padding>

                        <HBox maxWidth="1280" spacing="30">
                            <VBox alignment="TOP_CENTER" spacing="18" HBox.hgrow="ALWAYS">

                                <TextField fx:id="txtSearch" maxWidth="980" prefHeight="42" promptText="Search flowers ..." style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-font-size: 18px;" />

                            </VBox>
                        </HBox>

                        <TilePane fx:id="productTilePane" alignment="CENTER" hgap="30" prefColumns="4" prefTileHeight="280" prefTileWidth="190" vgap="28" />

                    </VBox>
                </content>
            </ScrollPane>

            <HBox alignment="CENTER" spacing="10" styleClass="pagination-box">
                <padding>
                    <Insets bottom="40" left="0" right="0" top="0" />
                </padding>

                <Button fx:id="btnPrev" onAction="#handlePrevPage" styleClass="primary-button" text="Prev" />

                <Label fx:id="lblPage" styleClass="pagination-label" text="Page 1" />

                <Button fx:id="btnNext" onAction="#handleNextPage" styleClass="primary-button" text="Next" />

            </HBox>

        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER" prefHeight="36.0" style="-fx-background-color: #f7c8d7;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 13px;" text="Flower Shop. flowershop@gmail.com" />
            </children>
        </HBox>
    </bottom>
   <left>
       <VBox prefWidth="230.0" spacing="40.0" style="-fx-background-color: #f3dfe3; -fx-padding: 14;" BorderPane.alignment="CENTER">
                  <children>
                      <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 24px; -fx-font-weight: 700;" text="Flowers" />

                                        <VBox spacing="8.0">
                          <children>
                              <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Price range" />
                              <ComboBox fx:id="cboPriceRange" prefWidth="160.0" />
                          </children>
                      </VBox>

                      <VBox spacing="6.0">
                          <children>
                              <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Category filter" />
                              <CheckBox fx:id="chkFresh" text="Hoa Tươi" />
                              <CheckBox fx:id="chkBirthday" text="Hoa Sinh Nhật" />
                              <CheckBox fx:id="chkWedding" text="Hoa Cưới" />
                              <CheckBox fx:id="chkFormal" text="Hoa Trang Trọng" />
                          </children>
                      </VBox>

                                        <VBox spacing="6.0">
                          <children>
                              <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Availability" />
                              <CheckBox fx:id="chkInStockOnly" text="In stock only" />
                          </children>
                      </VBox>

                                        <VBox spacing="8.0">
                          <children>
                              <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Sort by:" />
                              <ComboBox fx:id="cboSortBy" prefWidth="160.0" />
                          </children>
                      </VBox>

                      <Button onAction="#handleShowResults" prefHeight="34.0" prefWidth="140.0" style="-fx-font-size: 14px;" styleClass="primary-button" text="Show results" />
                  </children>
              </VBox>
   </left>

</BorderPane>
