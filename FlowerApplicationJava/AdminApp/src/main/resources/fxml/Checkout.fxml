<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f8eef1;" stylesheets="@../css/user-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.OrderController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="56.0" spacing="22.0" styleClass="top-bar">
            <padding>
                <Insets bottom="0.0" left="18.0" right="18.0" top="0.0" />
            </padding>

            <children>
                <Label styleClass="brand-label" text="Flower shop" />
                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#goHome" styleClass="nav-button" text="Home" />
                <Button onAction="#goFlowers" styleClass="nav-button" text="Flowers" />
                <Button onAction="#goCategories" styleClass="nav-button" text="Categories" />
                <Button onAction="#goContact" styleClass="nav-button" text="Contact" />
                <Button fx:id="btnCart" onAction="#goCart" styleClass="nav-button-active" text="Cart" />

                <Button onAction="#handleLogout" prefHeight="34.0" prefWidth="94.0" styleClass="logout-button" text="Log Out" />
            </children>
        </HBox>
    </top>

    <center>
        <StackPane style="-fx-background-color: #f8eef1;">
            <children>
                <VBox fx:id="mainBox" maxWidth="1260.0" prefWidth="1260.0" spacing="28.0">
                    <padding>
                        <Insets bottom="26.0" left="30.0" right="30.0" top="26.0" />
                    </padding>

                    <children>

                        <Label fx:id="lblCheckoutTitle" maxWidth="1260.0" prefHeight="42.0" style="-fx-background-color: #edd6d8; -fx-text-fill: #8e5f5f; -fx-font-size: 20px; -fx-font-weight: 700; -fx-padding: 8 0 0 16;" text="Checkout" />

                        <HBox spacing="80.0">
                            <children>

                                <!-- LEFT -->
                                <VBox fx:id="leftPanel" prefWidth="540.0" spacing="20.0">
                                    <children>
                                        <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 20px; -fx-font-weight: 700;" text="Customer Information" />

                                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                                            <children>
                                                <Label prefWidth="100.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Full name" />
                                                <TextField fx:id="txtFullName" prefWidth="250.0" style="-fx-background-color: #f6d6e0; -fx-text-fill: #8e5f5f;" />
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                                            <children>
                                                <Label prefWidth="100.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Email" />
                                                <TextField fx:id="txtEmail" prefWidth="250.0" style="-fx-background-color: #f6d6e0; -fx-text-fill: #8e5f5f;" />
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                                            <children>
                                                <Label prefWidth="100.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Phone" />
                                                <TextField fx:id="txtPhone" prefWidth="250.0" style="-fx-background-color: #f6d6e0; -fx-text-fill: #8e5f5f;" />
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                                            <children>
                                                <Label prefWidth="100.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 14px;" text="Address" />
                                                <TextArea fx:id="txtAddress" prefHeight="90.0" prefWidth="250.0" style="-fx-background-color: #f6d6e0; -fx-text-fill: #8e5f5f;" wrapText="true" />
                                            </children>
                                        </HBox>

                                        <VBox spacing="10.0">
                                            <children>
                                                <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 20px; -fx-font-weight: 700;" text="Payment Method" />

                                                <CheckBox fx:id="chkCreditCard" onAction="#handlePaymentSelection" text="Credit Card" />
                                                <CheckBox fx:id="chkPayPal" onAction="#handlePaymentSelection" text="VNPay" />
                                                <CheckBox fx:id="chkCashOnDelivery" onAction="#handlePaymentSelection" text="Cash on Delivery" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="10.0">
                                            <children>
                                                <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 20px; -fx-font-weight: 700;" text="Use Points" />

                                                <Label fx:id="lblCurrentPoints" style="-fx-text-fill: #8e5f5f; -fx-font-size: 15px;" text="Current points: 0" />

                                                <HBox alignment="CENTER_LEFT" spacing="16.0">
                                                    <children>
                                                        <Button fx:id="btnMinusPoint" onAction="#handleDecreasePoint" prefHeight="36.0" prefWidth="44.0" style="-fx-background-color: #edd6d8; -fx-text-fill: #8e5f5f; -fx-font-size: 18px; -fx-font-weight: 700; -fx-background-radius: 8; -fx-cursor: hand;" text="-" />

                                                        <Label fx:id="lblUsedPoints" prefWidth="40.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px; -fx-font-weight: 700;" text="0" />

                                                        <Button fx:id="btnPlusPoint" onAction="#handleIncreasePoint" prefHeight="36.0" prefWidth="44.0" style="-fx-background-color: #edd6d8; -fx-text-fill: #8e5f5f; -fx-font-size: 18px; -fx-font-weight: 700; -fx-background-radius: 8; -fx-cursor: hand;" text="+" />

                                                        <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 15px;" text="points used" />
                                                    </children>
                                                </HBox>

                                                <Label fx:id="lblPointRule" style="-fx-text-fill: #d06c95; -fx-font-size: 13px; -fx-font-style: italic;" text="1 point = voucher giảm 1,000VND" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <Region maxHeight="520.0" prefWidth="1.5" style="-fx-background-color: #f59bc0;" />

                                <!-- RIGHT -->
                                <VBox fx:id="rightPanel" prefWidth="380.0" spacing="18.0">
                                    <children>
                                        <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 20px; -fx-font-weight: 700;" text="Order Summary" />

                                        <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 18px;" text="--------------" />

                                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="180.0" style="-fx-background: transparent; -fx-background-color: transparent;" vbarPolicy="AS_NEEDED">
                                            <content>
                                                <VBox fx:id="orderItemsContainer" spacing="10.0" />
                                            </content>
                                        </ScrollPane>

                                        <Region prefHeight="10.0" />

                                        <HBox>
                                            <children>
                                                <Label prefWidth="220.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;" text="Subtotal" />
                                                <Label fx:id="lblSubtotal" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;" text="\$0" />
                                            </children>
                                        </HBox>

                                        <HBox>
                                            <children>
                                                <Label prefWidth="220.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;" text="Shipping" />
                                                <Label fx:id="lblShipping" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;" text="\$0" />
                                            </children>
                                        </HBox>

                                        <HBox>
                                            <children>
                                                <Label prefWidth="220.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;" text="Points discount" />
                                                <Label fx:id="lblDiscount" style="-fx-text-fill: #d06c95; -fx-font-size: 16px; -fx-font-weight: 700;" text="-$0" />
                                            </children>
                                        </HBox>

                                        <HBox>
                                            <children>
                                                <Label prefWidth="220.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px; -fx-font-weight: 700;" text="Total" />
                                                <Label fx:id="lblTotal" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px; -fx-font-weight: 700;" text="\$0" />
                                            </children>
                                        </HBox>

                                        <HBox>
                                            <children>
                                                <Label prefWidth="220.0" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;" text="Points earned" />
                                                <Label fx:id="lblEarnedPoints" style="-fx-text-fill: #8e5f5f; -fx-font-size: 16px;" text="+0" />
                                            </children>
                                        </HBox>

                                        <Button fx:id="btnPlaceOrder" onAction="#handlePlaceOrder" prefHeight="48.0" prefWidth="180.0" style="-fx-font-size: 24px; -fx-background-radius: 6;" styleClass="primary-button" text="Place Order" />
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="36.0" styleClass="footer-bar">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 13px;" text="Flower Shop. flowershop@gmail.com" />
            </children>
        </HBox>
    </bottom>

</BorderPane>
