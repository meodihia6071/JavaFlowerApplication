<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="700" prefWidth="1200"
      stylesheets="@../css/admin-style.css"
      styleClass="main-bg"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="flowershop.controllers.AdminCustomerController">

    <children>

        <VBox styleClass="sidebar">
            <children>
                <Label text="🌷 Flower Shop" styleClass="logo"/>

                <Separator prefWidth="210" styleClass="sidebar-separator">
                    <VBox.margin>
                        <Insets left="20" right="20" bottom="10"/>
                    </VBox.margin>
                </Separator>

                <Button text="🏠  Dashboard" onAction="#goDashboard" styleClass="menu-btn"/>
                <Button text="🌸  Products" onAction="#goProducts" styleClass="menu-btn"/>
                <Button text="📂  Categories" onAction="#goCategories" styleClass="menu-btn"/>
                <Button text="📦  Orders" onAction="#goOrders" styleClass="menu-btn"/>

                <Button text="👤  Customers"
                        styleClass="menu-btn"
                        style="
                            -fx-background-color:white;
                            -fx-text-fill:#e25a84;
                            -fx-font-weight:bold;
                            -fx-pref-width:250;
                            -fx-alignment:CENTER_LEFT;
                            -fx-padding:15 0 15 34;
                            -fx-border-width:0 0 0 6;
                            -fx-border-color:#e25a84;
                        "/>

                <Button text="🚚  Suppliers" onAction="#goSuppliers" styleClass="menu-btn"/>
                <Button text="📦  Stock" onAction="#goStock" styleClass="menu-btn"/>
                <Button text="👔  Employees" onAction="#goEmployees" styleClass="menu-btn"/>
                <Button text="📈  Reports" onAction="#goReports" styleClass="menu-btn"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER">
                    <padding>
                        <Insets top="20" bottom="30"/>
                    </padding>
                    <Button text="⏻ Log Out" onAction="#handleLogout" styleClass="logout-btn"/>
                </HBox>
            </children>
        </VBox>

        <HBox spacing="20" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <children>
                <VBox spacing="15" HBox.hgrow="ALWAYS">
                    <children>

                        <Label text="Customer Management" styleClass="page-title"/>

                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <children>
                                <Button text="➕ Add Customer" onAction="#handleAddCustomer" styleClass="tool-btn"/>
                                <Button text="✏ Edit" onAction="#handleEditCustomer" styleClass="tool-btn"/>
                                <Button text="🗑 Delete" onAction="#handleDeleteCustomer" styleClass="tool-btn"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <TextField fx:id="searchField" promptText="Search customer..." prefWidth="260" prefHeight="36" styleClass="search-box"/>
                                <Button text="🔍 Search" onAction="#handleSearch" styleClass="tool-btn"/>

                                <MenuButton text="⇅ Sort" styleClass="tool-btn">
                                    <items>
                                        <MenuItem text="Name A → Z" onAction="#sortNameAZ"/>
                                        <MenuItem text="Name Z → A" onAction="#sortNameZA"/>
                                        <MenuItem text="Newest" onAction="#sortNewest"/>
                                    </items>
                                </MenuButton>
                            </children>
                        </HBox>

                        <TableView fx:id="customerTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="colId" text="ID" prefWidth="80" styleClass="center-column"/>
                                <TableColumn fx:id="colName" text="Customer Name" prefWidth="220" styleClass="left-column"/>
                                <TableColumn fx:id="colUserId" text="User ID" prefWidth="80" styleClass="center-column" />
                                <TableColumn fx:id="colPhone" text="Phone" prefWidth="150" styleClass="center-column"/>
                                <TableColumn fx:id="colEmail" text="Email" prefWidth="220" styleClass="left-column"/>
                                <TableColumn fx:id="colPoints" text="Points" prefWidth="120" styleClass="center-column"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                    </children>
                </VBox>
            </children>
        </HBox>

    </children>
</HBox>