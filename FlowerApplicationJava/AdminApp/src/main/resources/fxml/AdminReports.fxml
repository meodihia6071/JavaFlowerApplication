<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<HBox prefHeight="650"
      prefWidth="1100"
      stylesheets="@../css/admin-style.css"
      styleClass="main-bg"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="flowershop.controllers.AdminReportsController">

    <children>

        <!-- SIDEBAR -->
        <VBox prefWidth="230" styleClass="sidebar">

            <children>

                <Label text="🌷 Flower Shop" styleClass="logo"/>

                <Separator prefWidth="180" styleClass="sidebar-separator"/>

                <Button text="🏠 Dashboard" onAction="#goDashboard" styleClass="menu-btn"/>
                <Button text="🌸 Products" onAction="#goProducts" styleClass="menu-btn"/>
                <Button text="📂 Categories" onAction="#goCategories" styleClass="menu-btn"/>
                <Button text="📦 Orders" onAction="#goOrders" styleClass="menu-btn"/>
                <Button text="👤 Customers" onAction="#goCustomers" styleClass="menu-btn"/>
                <Button text="🚚 Suppliers" onAction="#goSuppliers" styleClass="menu-btn"/>
                <Button text="📦 Stock" onAction="#goStock" styleClass="menu-btn"/>

                <!-- ACTIVE -->
                <Button text="📈 Reports"
                        styleClass="menu-btn"
                        style="
                            -fx-background-color:white;
                            -fx-text-fill:#e25a84;
                            -fx-font-weight:bold;
                            -fx-pref-width:230;
                            -fx-alignment:CENTER_LEFT;
                            -fx-padding:15 0 15 30;
                            -fx-border-width:0 0 0 6;
                            -fx-border-color:#e25a84;
                        "/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER" spacing="10">

                    <padding>
                        <Insets top="20" bottom="20"/>
                    </padding>
                    <Button text="⏻ Log Out"
                            onAction="#handleLogout"
                            styleClass="logout-btn"/>
                </HBox>

            </children>

        </VBox>

        <!-- MAIN CONTENT -->
        <VBox spacing="25"
              styleClass="main-content"
              HBox.hgrow="ALWAYS">

            <padding>
                <Insets top="40" left="40" right="40"/>
            </padding>

            <children>

                <Label text="Reports Dashboard"
                       styleClass="page-title"/>

                <!-- SUMMARY CARDS -->
                <HBox spacing="20">

                    <VBox styleClass="report-card">
                        <Label text="🌸 Products"/>
                        <Label fx:id="totalProducts" styleClass="report-number"/>
                    </VBox>

                    <VBox styleClass="report-card">
                        <Label text="📦 Orders"/>
                        <Label fx:id="totalOrders" styleClass="report-number"/>
                    </VBox>

                    <VBox styleClass="report-card">
                        <Label text="👤 Customers"/>
                        <Label fx:id="totalCustomers" styleClass="report-number"/>
                    </VBox>

                    <VBox styleClass="report-card">
                        <Label text="💰 Revenue"/>
                        <Label fx:id="totalRevenue" styleClass="report-number"/>
                    </VBox>

                </HBox>


                <!-- CHART AREA -->
                <HBox spacing="20">

                    <!-- REVENUE CHART -->
                    <BarChart fx:id="revenueChart"
                              prefWidth="550"
                              prefHeight="350"
                              animated="false">

                        <xAxis>
                            <CategoryAxis fx:id="xAxis" label="Month"/>
                        </xAxis>

                        <yAxis>
                            <NumberAxis fx:id="yAxis" label="Revenue"/>
                        </yAxis>

                    </BarChart>


                    <!-- TOP FLOWERS -->
                    <PieChart fx:id="topProductsChart"
                              prefWidth="350"
                              prefHeight="350"/>

                </HBox>


                <!-- RECENT ORDERS -->
                <VBox spacing="10">

                    <Label text="Recent Orders"
                           style="-fx-font-size:18px;-fx-font-weight:bold;"/>

                    <TableView fx:id="recentOrdersTable"
                               prefHeight="180">

                        <columns>

                            <TableColumn fx:id="colOrderId"
                                         text="Order ID"
                                         prefWidth="100"/>

                            <TableColumn fx:id="colCustomer"
                                         text="Customer"
                                         prefWidth="200"/>

                            <TableColumn fx:id="colDate"
                                         text="Date"
                                         prefWidth="150"/>

                            <TableColumn fx:id="colTotal"
                                         text="Total"
                                         prefWidth="120"/>

                        </columns>

                    </TableView>

                </VBox>

            </children>

        </VBox>

    </children>

</HBox>