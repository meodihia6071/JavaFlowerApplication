<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.image.*?>

<HBox prefHeight="650"
      prefWidth="1100"
      stylesheets="@../css/admin-style.css"
      styleClass="main-bg"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="flowershop.controllers.AdminReportsController">

    <children>

        <!-- SIDEBAR -->
        <VBox prefWidth="230" styleClass="sidebar">

            <children>

                <Label text="🌷 Flower Shop" styleClass="logo"/>

                <Separator prefWidth="180" styleClass="sidebar-separator"/>

                <Button text="🏠 Dashboard" onAction="#goDashboard" styleClass="menu-btn"/>
                <Button text="🌸 Products" onAction="#goProducts" styleClass="menu-btn"/>
                <Button text="📂 Categories" onAction="#goCategories" styleClass="menu-btn"/>
                <Button text="📦 Orders" onAction="#goOrders" styleClass="menu-btn"/>
                <Button text="👤 Customers" onAction="#goCustomers" styleClass="menu-btn"/>
                <Button text="🚚 Suppliers" onAction="#goSuppliers" styleClass="menu-btn"/>
                <Button text="📦 Stock" onAction="#goStock" styleClass="menu-btn"/>
                <Button text="👨‍💼 Employees" onAction="#goEmployees" styleClass="menu-btn"/>

                <!-- ACTIVE -->
                <Button text="📈 Reports"
                        styleClass="menu-btn"
                        style="
                            -fx-background-color:white;
                            -fx-text-fill:#e25a84;
                            -fx-font-weight:bold;
                            -fx-pref-width:230;
                            -fx-alignment:CENTER_LEFT;
                            -fx-padding:15 0 15 30;
                            -fx-border-width:0 0 0 6;
                            -fx-border-color:#e25a84;
                        "/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER" spacing="10">

                    <padding>
                        <Insets top="20" bottom="20"/>
                    </padding>
                    <Button text="⏻ Log Out"
                            onAction="#handleLogout"
                            styleClass="logout-btn"/>
                </HBox>

            </children>

        </VBox>

        <!-- MAIN CONTENT -->
        <VBox spacing="25"
              styleClass="main-content"
              HBox.hgrow="ALWAYS">

            <padding>
                <Insets top="30" left="40" right="40"/>
            </padding>

            <children>

                <!-- HEADER + FILTER -->
                <HBox spacing="15" alignment="CENTER_LEFT">

                    <Label text="Reports Dashboard"
                           styleClass="page-title"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <DatePicker fx:id="fromDate"/>
                    <DatePicker fx:id="toDate"/>

                    <HBox spacing="10">

                        <Button text="🔄 Refresh" onAction="#handleRefresh" styleClass="refresh-btn"/>
                        <Button text="📤 Export" onAction="#handleExport" styleClass="export-btn"/>

                    </HBox>

                </HBox>


                <!-- SUMMARY CARDS -->
                <ScrollPane fitToHeight="true"
                            fitToWidth="false"
                            hbarPolicy="AS_NEEDED"
                            vbarPolicy="NEVER"
                            style="-fx-background-color:transparent;">

                    <content>
                        <HBox spacing="20">

                            <VBox styleClass="report-card">
                                <Label text="🌸 Products"/>
                                <Label fx:id="totalProducts" styleClass="report-number"/>
                            </VBox>

                            <VBox styleClass="report-card">
                                <Label text="📦 Orders"/>
                                <Label fx:id="totalOrders" styleClass="report-number"/>
                            </VBox>

                            <VBox styleClass="report-card">
                                <Label text="👤 Customers"/>
                                <Label fx:id="totalCustomers" styleClass="report-number"/>
                            </VBox>

                            <VBox styleClass="report-card">
                                <Label text="💰 Revenue"/>
                                <Label fx:id="totalRevenue" styleClass="report-number"/>
                            </VBox>

                            <VBox styleClass="report-card">
                                <Label text="📈 Profit"/>
                                <Label fx:id="totalProfit" styleClass="report-number"/>
                            </VBox>

                            <VBox styleClass="report-card">
                                <Label text="🛒 Avg Order"/>
                                <Label fx:id="avgOrderValue" styleClass="report-number"/>
                            </VBox>

                        </HBox>
                    </content>

                </ScrollPane>


                <!-- CHARTS -->
                <HBox spacing="20">

                    <!-- BAR CHART -->
                    <BarChart fx:id="revenueChart" prefWidth="400" prefHeight="300">
                        <xAxis>
                            <CategoryAxis label="Month"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Revenue"/>
                        </yAxis>
                    </BarChart>

                    <!-- LINE CHART -->
                    <LineChart fx:id="trendChart" prefWidth="400" prefHeight="300">
                        <xAxis>
                            <CategoryAxis label="Time"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Orders"/>
                        </yAxis>
                    </LineChart>

                    <!-- PIE -->
                    <PieChart fx:id="topProductsChart"
                              prefWidth="300"
                              prefHeight="300"/>

                </HBox>


                <!-- INSIGHT SECTION -->
                <HBox spacing="20">

                    <!-- TOP CUSTOMERS -->
                    <VBox spacing="10" HBox.hgrow="ALWAYS">

                        <Label text="👑 Top Customers"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <TableView fx:id="topCustomersTable" prefHeight="200">

                            <columns>
                                <TableColumn fx:id="colCusName" text="Name" prefWidth="180"/>
                                <TableColumn fx:id="colCusOrders" text="Orders" prefWidth="100" styleClass="center-column"/>
                                <TableColumn fx:id="colCusSpent" text="Spent" prefWidth="120" styleClass="center-column"/>
                            </columns>

                        </TableView>

                    </VBox>


                    <!-- LOW STOCK -->
                    <VBox spacing="10" HBox.hgrow="ALWAYS">

                        <Label text="⚠ Low Stock"
                               style="-fx-font-size:16px;-fx-font-weight:bold;"/>

                        <TableView fx:id="lowStockTable" prefHeight="200">

                            <columns>
                                <TableColumn fx:id="colProductName" text="Product" prefWidth="160"/>
                                <TableColumn fx:id="colStockQty" text="Quantity" prefWidth="80" styleClass="center-column"/>
                            </columns>

                        </TableView>

                    </VBox>

                    <HBox prefWidth="260">

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- GIF RIGHT -->
                        <VBox alignment="CENTER"
                              spacing="5"
                              prefWidth="220">

                            <HBox HBox.hgrow="ALWAYS">
                                <Region HBox.hgrow="ALWAYS"/>
                                <ImageView fx:id="assistantImage"
                                           fitWidth="180"
                                           preserveRatio="true"/>
                            </HBox>

                            <Label fx:id="assistantText"
                                   wrapText="true"
                                   style="-fx-text-fill:#777; -fx-font-size:13px;"/>
                        </VBox>

                    </HBox>

                </HBox>

            </children>

        </VBox>

    </children>

</HBox>