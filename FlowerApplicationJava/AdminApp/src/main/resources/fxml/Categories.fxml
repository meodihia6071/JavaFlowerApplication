<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f8eef1;" stylesheets="@../css/user-style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.CategoryController">

   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="56.0" spacing="22.0" styleClass="top-bar">
         <padding>
            <Insets bottom="0.0" left="18.0" right="18.0" top="0.0" />
         </padding>

         <children>
            <Label text="Flower shop" styleClass="brand-label" />
            <Region HBox.hgrow="ALWAYS" />

            <Button text="Home" onAction="#goHome" styleClass="nav-button" />
            <Button text="Flowers" onAction="#goFlowers" styleClass="nav-button" />
            <Button text="Categories" onAction="#goCategories" styleClass="nav-button-active" />
            <Button text="Contact" onAction="#goContact" styleClass="nav-button" />
            <Button fx:id="btnCart" text="Cart" onAction="#goCart" styleClass="nav-button" />
            <Button text="Log Out" onAction="#handleLogout"
                    prefHeight="34.0" prefWidth="94.0"
                    styleClass="logout-button" />
         </children>
      </HBox>
   </top>

   <center>
      <ScrollPane fx:id="categoryScroll" fitToWidth="true" hbarPolicy="NEVER">
         <content>
            <VBox alignment="TOP_CENTER" spacing="30.0" fillWidth="true">
               <children>

                  <!-- Birthday -->
                  <VBox fx:id="birthdaySection" alignment="TOP_CENTER" spacing="12.0">
                     <children>
                        <Label text="Birthday Flowers"
                               style="-fx-text-fill: #9b6666; -fx-font-size: 24px; -fx-font-weight: 700;"
                               alignment="CENTER"
                               maxWidth="Infinity"/>

                        <HBox fx:id="birthdayContainer"
                              alignment="CENTER"
                              spacing="20.0"
                              maxWidth="1200.0"
                              prefWidth="1200.0"/>
                     </children>
                  </VBox>

                  <!-- Wedding -->
                  <VBox fx:id="weddingSection" alignment="TOP_CENTER" spacing="12.0">
                     <children>
                        <Label text="Wedding Flowers"
                               style="-fx-text-fill: #9b6666; -fx-font-size: 24px; -fx-font-weight: 700;"
                               alignment="CENTER"
                               maxWidth="Infinity"/>

                        <HBox fx:id="weddingContainer"
                              alignment="CENTER"
                              spacing="20.0"
                              maxWidth="1200.0"
                              prefWidth="1200.0"/>
                     </children>
                  </VBox>

                  <!-- Anniversary -->
                  <VBox fx:id="anniversarySection" alignment="TOP_CENTER" spacing="12.0">
                     <children>
                        <Label text="Anniversary Flowers"
                               style="-fx-text-fill: #9b6666; -fx-font-size: 24px; -fx-font-weight: 700;"
                               alignment="CENTER"
                               maxWidth="Infinity"/>

                        <HBox fx:id="anniversaryContainer"
                              alignment="CENTER"
                              spacing="20.0"
                              maxWidth="1200.0"
                              prefWidth="1200.0"/>
                     </children>
                  </VBox>

                  <!-- Sympathy -->
                  <VBox fx:id="sympathySection" alignment="TOP_CENTER" spacing="12.0">
                     <children>
                        <Label text="Sympathy Flowers"
                               style="-fx-text-fill: #9b6666; -fx-font-size: 24px; -fx-font-weight: 700;"
                               alignment="CENTER"
                               maxWidth="Infinity"/>

                        <HBox fx:id="sympathyContainer"
                              alignment="CENTER"
                              spacing="20.0"
                              maxWidth="1200.0"
                              prefWidth="1200.0"/>
                     </children>
                  </VBox>

               </children>

               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </center>

   <bottom>
      <HBox alignment="CENTER" prefHeight="36.0" style="-fx-background-color: #f7c8d7;">
         <children>
            <Label style="-fx-text-fill: white; -fx-font-size: 13px;" text="Flower Shop. flowershop@gmail.com" />
         </children>
      </HBox>
   </bottom>

</BorderPane>