<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f8eef1;" stylesheets="@../css/user-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.CategoryController">

   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="56.0" spacing="22.0" styleClass="top-bar">
         <padding>
            <Insets bottom="0.0" left="18.0" right="18.0" top="0.0" />
         </padding>

         <children>
            <Label style="-fx-font-weight: 700; -fx-font-size: 25px;" styleClass="brand-label" text="Flower shop" />
            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#goHome" styleClass="nav-button" text="Home" />
            <Button onAction="#goFlowers" styleClass="nav-button" text="Flowers" />
            <Button onAction="#goCategories" styleClass="nav-button-active" text="Categories" />
            <Button onAction="#goContact" styleClass="nav-button" text="Contact" />
            <Button fx:id="btnCart" onAction="#goCart" styleClass="nav-button" text="Cart" />
            <Button onAction="#handleLogout" prefHeight="34.0" prefWidth="94.0" styleClass="logout-button" text="Log Out" />
         </children>
      </HBox>
   </top>

   <center>
      <ScrollPane fx:id="categoryScroll" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #f8eef1; -fx-background-color: #f8eef1;" vbarPolicy="AS_NEEDED">
         <content>
            <VBox alignment="TOP_CENTER" fillWidth="true" spacing="30.0">
               <children>

                  <VBox fx:id="freshSection" alignment="TOP_CENTER" spacing="12.0">
                     <children>
                        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #9b6666; -fx-font-size: 24px; -fx-font-weight: 700;" text="Hoa Tươi" />
                        <HBox fx:id="freshContainer" alignment="CENTER" maxWidth="1200.0" prefWidth="1200.0" spacing="20.0" />
                     </children>
                  </VBox>

                  <VBox fx:id="birthdaySection" alignment="TOP_CENTER" spacing="12.0">
                     <children>
                        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #9b6666; -fx-font-size: 24px; -fx-font-weight: 700;" text="Hoa Sinh Nhật" />
                        <HBox fx:id="birthdayContainer" alignment="CENTER" maxWidth="1200.0" prefWidth="1200.0" spacing="20.0" />
                     </children>
                  </VBox>

                  <VBox fx:id="weddingSection" alignment="TOP_CENTER" spacing="12.0">
                     <children>
                        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #9b6666; -fx-font-size: 24px; -fx-font-weight: 700;" text="Hoa Cưới" />
                        <HBox fx:id="weddingContainer" alignment="CENTER" maxWidth="1200.0" prefWidth="1200.0" spacing="20.0" />
                     </children>
                  </VBox>

                  <VBox fx:id="formalSection" alignment="TOP_CENTER" spacing="12.0">
                     <children>
                        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #9b6666; -fx-font-size: 24px; -fx-font-weight: 700;" text="Hoa Trang Trọng">
                           <VBox.margin>
                              <Insets bottom="10.0" />
                           </VBox.margin>
                        </Label>
                        <HBox fx:id="formalContainer" alignment="CENTER" maxWidth="1200.0" prefWidth="1200.0" spacing="20.0" />
                     </children>
                  </VBox>

               </children>

               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </center>

   <bottom>
      <HBox alignment="CENTER" prefHeight="36.0" style="-fx-background-color: #f7c8d7;">
         <children>
            <Label style="-fx-text-fill: white; -fx-font-size: 13px;" text="Flower Shop. flowershop@gmail.com" />
         </children>
      </HBox>
   </bottom>

</BorderPane>
