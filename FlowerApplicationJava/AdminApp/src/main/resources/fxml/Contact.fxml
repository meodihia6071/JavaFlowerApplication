<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f8eef1;" stylesheets="@../css/user-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.ContactController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="56.0" spacing="22.0" styleClass="top-bar">
            <padding>
                <Insets bottom="0" left="18" right="18" top="0" />
            </padding>

            <children>
                <Label style="-fx-font-weight: 700; -fx-font-size: 25px;" styleClass="brand-label" text="Flower shop" />

                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#goHome" styleClass="nav-button" text="Home" />
                <Button onAction="#goFlowers" styleClass="nav-button" text="Flowers" />
                <Button onAction="#goCategories" styleClass="nav-button" text="Categories" />
                <Button styleClass="nav-button-active" text="Contact" />
                <Button fx:id="btnCart" onAction="#goCart" styleClass="nav-button" text="Cart" />

                <Button onAction="#handleLogout" prefHeight="34" prefWidth="94" styleClass="logout-button" text="Log Out" />
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #f8eef1; -fx-background-color: #f8eef1;" vbarPolicy="AS_NEEDED">
            <content>
                <VBox alignment="TOP_CENTER" spacing="28" style="-fx-background-color: #f8eef1;">
                    <padding>
                        <Insets bottom="28" left="24" right="24" top="26" />
                    </padding>

                    <children>

                        <VBox alignment="CENTER" spacing="8">
                            <children>
                                <Label fx:id="lblTitle" style="-fx-font-size: 30px; -fx-text-fill: #8e5f5f; -fx-font-weight: 800;" text="Contact Us" />

                                <Label fx:id="lblSubtitle" maxWidth="780" style="-fx-font-size: 15px; -fx-text-fill: #b07a7a;" text="We are always ready to listen and help you choose the perfect flowers." wrapText="true" />
                            </children>
                        </VBox>

                        <HBox alignment="TOP_CENTER" maxWidth="1180" prefWidth="1180" spacing="34">
                            <children>

                                <VBox fx:id="storeCard" minHeight="360" prefWidth="540" spacing="18" style="-fx-background-color:#f5dce2; -fx-background-radius:16; -fx-padding:28; -fx-border-color:#f0c7d2; -fx-border-radius:16;">
                                    <children>
                                        <Label style="-fx-font-size:22px; -fx-font-weight:800; -fx-text-fill:#8e5f5f;" text="Flower Shop" />

                                        <Label style="-fx-font-size:15px; -fx-text-fill:#9b6666; -fx-line-spacing:3;" text="Flower Shop là địa chỉ tin cậy dành cho những ai đang tìm kiếm các bó hoa tươi, giỏ hoa và lẵng hoa mang phong cách nhẹ nhàng, tinh tế. Chúng tôi tập trung vào trải nghiệm đặt hoa trực tuyến nhanh, dễ dùng và phù hợp cho nhiều dịp như sinh nhật, kỷ niệm, cưới hỏi và chia buồn." wrapText="true" />

                                        <Separator style="-fx-background-color:#e8b9c8;" />

                                        <VBox spacing="10">
                                            <children>
                                                <Label style="-fx-font-size:18px; -fx-font-weight:700; -fx-text-fill:#8e5f5f;" text="Why choose us?" />

                                                <Label style="-fx-font-size:14px; -fx-text-fill:#9b6666;" text="• Giao diện đặt hoa đơn giản, dễ thao tác" />
                                                <Label style="-fx-font-size:14px; -fx-text-fill:#9b6666;" text="• Nhiều mẫu hoa theo danh mục dịp sử dụng" />
                                                <Label style="-fx-font-size:14px; -fx-text-fill:#9b6666;" text="• Hỗ trợ ghi chú riêng cho từng sản phẩm" />
                                                <Label style="-fx-font-size:14px; -fx-text-fill:#9b6666;" text="• Theo dõi giỏ hàng nhanh ngay trên thanh menu" />
                                            </children>
                                        </VBox>

                                        <Region VBox.vgrow="ALWAYS" />

                                        <HBox spacing="14">
                                            <children>
                                                <VBox prefWidth="220" spacing="6" style="-fx-background-color:#f8eef1; -fx-background-radius:12; -fx-padding:14;">
                                                    <children>
                                                        <Label style="-fx-font-size:15px; -fx-font-weight:700; -fx-text-fill:#8e5f5f;" text="Opening Hours" />
                                                        <Label style="-fx-font-size:14px; -fx-text-fill:#b07a7a;" text="08:00 - 21:00 mỗi ngày" />
                                                    </children>
                                                </VBox>

                                                <VBox prefWidth="220" spacing="6" style="-fx-background-color:#f8eef1; -fx-background-radius:12; -fx-padding:14;">
                                                    <children>
                                                        <Label style="-fx-font-size:15px; -fx-font-weight:700; -fx-text-fill:#8e5f5f;" text="Customer Support" />
                                                        <Label style="-fx-font-size:14px; -fx-text-fill:#b07a7a;" text="Luôn sẵn sàng hỗ trợ đặt hoa" wrapText="true" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="formCard" minHeight="360" prefWidth="540" spacing="16" style="-fx-background-color:#f5dce2; -fx-background-radius:16; -fx-padding:28; -fx-border-color:#f0c7d2; -fx-border-radius:16;">
                                    <children>
                                        <Label style="-fx-font-size:22px; -fx-font-weight:800; -fx-text-fill:#8e5f5f;" text="Send Message" />

                                        <Label style="-fx-font-size:14px; -fx-text-fill:#b07a7a;" text="Leave your message here and we will contact you as soon as possible." wrapText="true" />

                                        <TextField fx:id="txtName" prefHeight="42" promptText="Your Name" style="-fx-background-color:#fffafc; -fx-background-radius:10; -fx-border-color:#ecc2cf; -fx-border-radius:10; -fx-text-fill:#8e5f5f; -fx-prompt-text-fill:#c69b9b; -fx-font-size:14px;" />

                                        <TextField fx:id="txtEmail" prefHeight="42" promptText="Your Email" style="-fx-background-color:#fffafc; -fx-background-radius:10; -fx-border-color:#ecc2cf; -fx-border-radius:10; -fx-text-fill:#8e5f5f; -fx-prompt-text-fill:#c69b9b; -fx-font-size:14px;" />

                                        <TextArea fx:id="txtMessage" prefHeight="190" promptText="Your Message" style="-fx-background-color:#fffafc; -fx-background-radius:10; -fx-border-color:#ecc2cf; -fx-border-radius:10; -fx-text-fill:#8e5f5f; -fx-prompt-text-fill:#c69b9b; -fx-font-size:14px;" wrapText="true" />

                                        <HBox alignment="CENTER_RIGHT" spacing="12">
                                            <children>
                                                <Button fx:id="btnClear" onAction="#handleClear" prefHeight="38" prefWidth="100" style="-fx-background-color:#edd6d8; -fx-text-fill:#8e5f5f; -fx-font-size:14px; -fx-font-weight:700; -fx-background-radius:10; -fx-cursor:hand;" text="Clear" />

                                                <Button fx:id="btnSend" onAction="#handleSendMessage" prefHeight="38" prefWidth="150" style="-fx-font-size:15px; -fx-background-radius:10;" styleClass="primary-button" text="Send Message" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <HBox alignment="CENTER" maxWidth="1180" prefWidth="1180" spacing="24">
                            <children>

                                <VBox fx:id="addressBox" alignment="CENTER" prefWidth="370" spacing="8" style="-fx-background-color:#f5dce2; -fx-background-radius:14; -fx-padding:18;">
                                    <children>
                                        <Label style="-fx-font-weight:800; -fx-text-fill:#8e5f5f; -fx-font-size:16px;" text="ĐỊA CHỈ" />
                                        <Label alignment="CENTER" maxWidth="300" style="-fx-text-fill:#9b6666; -fx-font-size:14px;" text="Số 4, ngách 1 ngõ 34, Âu Cơ, Tây Hồ" wrapText="true" />
                                    </children>
                                </VBox>

                                <VBox fx:id="phoneBox" alignment="CENTER" prefWidth="370" spacing="8" style="-fx-background-color:#f5dce2; -fx-background-radius:14; -fx-padding:18;">
                                    <children>
                                        <Label style="-fx-font-weight:800; -fx-text-fill:#8e5f5f; -fx-font-size:16px;" text="PHONE" />
                                        <Label style="-fx-text-fill:#f28c8c; -fx-font-size:15px; -fx-font-weight:700;" text="0359341138" />
                                    </children>
                                </VBox>

                                <VBox fx:id="emailBox" alignment="CENTER" prefWidth="370" spacing="8" style="-fx-background-color:#f5dce2; -fx-background-radius:14; -fx-padding:18;">
                                    <children>
                                        <Label style="-fx-font-weight:800; -fx-text-fill:#8e5f5f; -fx-font-size:16px;" text="EMAIL" />
                                        <Label style="-fx-text-fill:#f28c8c; -fx-font-size:15px; -fx-font-weight:700;" text="camfloralhouse@gmail.com" wrapText="true" />
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="36.0" styleClass="footer-bar">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 13px;" text="Flower Shop. flowershop@gmail.com" />
            </children>
        </HBox>
    </bottom>

</BorderPane>
