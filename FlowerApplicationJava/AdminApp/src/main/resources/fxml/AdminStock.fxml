<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="650" prefWidth="1100"
      stylesheets="@../css/admin-style.css"
      styleClass="main-bg"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="flowershop.controllers.AdminStockController">

    <children>

        <!-- SIDEBAR -->
        <VBox prefWidth="230" styleClass="sidebar">

            <children>

                <Label text="🌷 Flower Shop" styleClass="logo"/>

                <Separator prefWidth="180" styleClass="sidebar-separator"/>

                <Button text="🏠 Dashboard" onAction="#goDashboard" styleClass="menu-btn"/>

                <Button text="🌸 Products" onAction="#goProducts" styleClass="menu-btn"/>

                <Button text="📂 Categories" onAction="#goCategories" styleClass="menu-btn"/>

                <Button text="📦 Orders" onAction="#goOrders" styleClass="menu-btn"/>

                <Button text="👤 Customers" onAction="#goCustomers" styleClass="menu-btn"/>

                <Button text="🚚 Suppliers" onAction="#goSuppliers" styleClass="menu-btn"/>

                <Button text="📦 Stock"
                        styleClass="menu-btn"
                        style="
                            -fx-background-color:white;
                            -fx-text-fill:#e25a84;
                            -fx-font-weight:bold;
                            -fx-pref-width:230;
                            -fx-alignment:CENTER_LEFT;
                            -fx-padding:15 0 15 30;
                            -fx-border-width:0 0 0 6;
                            -fx-border-color:#e25a84;
                            -fx-background-radius:0;
                            -fx-border-radius:0;
                            "/>
                <Button text="👨‍💼 Employees" onAction="#goEmployees" styleClass="menu-btn"/>
                <Button text="📈 Reports" onAction="#goReports" styleClass="menu-btn"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER" spacing="10">

                    <padding>
                        <Insets top="20" bottom="20"/>
                    </padding>
                    <Button text="⏻ Log Out"
                            onAction="#handleLogout"
                            styleClass="logout-btn"/>
                </HBox>

            </children>

        </VBox>

        <!-- MAIN -->
        <VBox spacing="20"
              styleClass="main-content"
              HBox.hgrow="ALWAYS">

            <padding>
                <Insets top="40" left="40" right="40"/>
            </padding>

            <children>

                <Label text="Stock Management"
                       styleClass="page-title"/>

                <HBox spacing="15" alignment="CENTER_LEFT">

                    <Button text="➕ Add Stock"
                            onAction="#handleAddStock"
                            styleClass="tool-btn"/>

                    <Button text="✏ Edit"
                            onAction="#handleEditStock"
                            styleClass="tool-btn"/>

                    <Button text="🗑 Delete"
                            onAction="#handleDeleteStock"
                            styleClass="tool-btn"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <TextField fx:id="searchField"
                               promptText="Search product..."
                               prefWidth="260"
                               prefHeight="36"
                               styleClass="search-box"/>

                    <Button text="🔍 Search"
                            onAction="#handleSearch"
                            styleClass="tool-btn"/>

                    <MenuButton text="⇅ Sort"
                                styleClass="tool-btn">

                        <items>
                            <MenuItem text="Name A → Z" onAction="#sortNameAZ"/>
                            <MenuItem text="Name Z → A" onAction="#sortNameZA"/>
                            <MenuItem text="Quantity ↑" onAction="#sortQuantityAsc"/>
                            <MenuItem text="Quantity ↓" onAction="#sortQuantityDesc"/>
                            <MenuItem text="Newest" onAction="#sortNewest"/>
                        </items>

                    </MenuButton>

                </HBox>

                <TableView fx:id="stockTable"
                           VBox.vgrow="ALWAYS">

                    <columns>

                        <TableColumn fx:id="colId" text="ID" prefWidth="70" styleClass="center-column"/>
                        <TableColumn fx:id="colProduct" text="Product Name" prefWidth="240" styleClass="left-column"/>
                        <TableColumn fx:id="colSupplier" text="Supplier" prefWidth="180" styleClass="left-column"/>
                        <TableColumn fx:id="colImportPrice" text="Import Price" prefWidth="120" styleClass="center-column"/>
                        <TableColumn fx:id="colQuantity" text="Quantity" prefWidth="100" styleClass="center-column"/>
                        <TableColumn fx:id="colImportDate" text="Import Date" prefWidth="150" styleClass="center-column"/>

                    </columns>

                </TableView>

            </children>

        </VBox>

    </children>

</HBox>