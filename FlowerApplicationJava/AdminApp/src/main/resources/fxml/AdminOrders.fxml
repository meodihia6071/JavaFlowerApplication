<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="700" prefWidth="1200"
      stylesheets="@../css/admin-style.css"
      styleClass="main-bg"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="flowershop.controllers.AdminOrdersController">

    <children>

        <VBox prefWidth="250" styleClass="sidebar">
            <children>
                <Label text="🌷 Flower Shop" styleClass="logo"/>

                <Separator prefWidth="210" styleClass="sidebar-separator">
                    <VBox.margin>
                        <Insets left="20" right="20" bottom="10"/>
                    </VBox.margin>
                </Separator>

                <Button text="🏠  Dashboard" onAction="#goDashboard" styleClass="menu-btn"/>
                <Button text="🌸  Products" onAction="#goProducts" styleClass="menu-btn"/>
                <Button text="📂  Categories" onAction="#goCategories" styleClass="menu-btn"/>

                <Button text="📦  Orders"
                        styleClass="menu-btn"
                        style="
                            -fx-background-color:white;
                            -fx-text-fill:#e25a84;
                            -fx-font-weight:bold;
                            -fx-pref-width:250;
                            -fx-alignment:CENTER_LEFT;
                            -fx-padding:15 0 15 34;
                            -fx-border-width:0 0 0 6;
                            -fx-border-color:#e25a84;
                        "/>

                <Button text="👤  Customers" onAction="#goCustomers" styleClass="menu-btn"/>
                <Button text="🚚  Suppliers" onAction="#goSuppliers" styleClass="menu-btn"/>
                <Button text="📦  Stock" onAction="#goStock" styleClass="menu-btn"/>
                <Button text="👔  Employees" onAction="#goEmployees" styleClass="menu-btn"/>
                <Button text="📈  Reports" onAction="#goReports" styleClass="menu-btn"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER">
                    <padding>
                        <Insets top="20" bottom="30"/>
                    </padding>
                    <Button text="⏻ Log Out" onAction="#handleLogout" styleClass="logout-btn"/>
                </HBox>
            </children>
        </VBox>

        <HBox spacing="30" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="40" left="40" right="40" bottom="40"/>
            </padding>
            <children>

                <VBox spacing="15" HBox.hgrow="ALWAYS">
                    <Label text="Orders" styleClass="page-title"/>
                    <TableView fx:id="orderTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colOrderId" text="ID" prefWidth="60" styleClass="center-column"/>
                            <TableColumn fx:id="colCustomer" text="Customer" prefWidth="150" styleClass="left-column"/>
                            <TableColumn fx:id="colDate" text="Date" prefWidth="120" styleClass="center-column"/>
                            <TableColumn fx:id="colTotal" text="Total" prefWidth="100" styleClass="center-column"/>
                            <TableColumn fx:id="colStatus" text="Status" prefWidth="100" styleClass="center-column"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox spacing="15" prefWidth="450">
                    <Label text="Order Details" styleClass="page-title"/>
                    <TableView fx:id="detailTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colProduct" text="Product" prefWidth="180" styleClass="left-column"/>
                            <TableColumn fx:id="colQty" text="Qty" prefWidth="60" styleClass="center-column"/>
                            <TableColumn fx:id="colPrice" text="Price" prefWidth="100" styleClass="center-column"/>
                            <TableColumn fx:id="colSubTotal" text="Total" prefWidth="110" styleClass="center-column"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

            </children>
        </HBox>

    </children>
</HBox>