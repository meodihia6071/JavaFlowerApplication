<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f8eef1;" stylesheets="@../css/user-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.CartController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="56.0" spacing="22.0" style="-fx-background-color: #f7c8d7;">
            <padding>
                <Insets bottom="0.0" left="18.0" right="18.0" top="0.0" />
            </padding>
            <children>
                <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 24px; -fx-font-weight: 500;" text="Flower shop" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#goHome" style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 18px;" text="Home" />
                <Button onAction="#goFlowers" style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 18px;" text="Flowers" />
                <Button onAction="#goCategories" style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 18px;" text="Categories" />
                <Button onAction="#goContact" style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 18px;" text="Contact" />
                <Button onAction="#goCart" style="-fx-background-color: transparent; -fx-text-fill: #8e5f5f; -fx-font-size: 18px; -fx-underline: true;" text="Cart" />
                <Button onAction="#handleLogout" prefHeight="34.0" prefWidth="94.0" style="-fx-background-color: #f59bc0; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 700; -fx-background-radius: 6;" text="Log Out" />
            </children>
        </HBox>
    </top>

    <center>
        <BorderPane>
            <top>
                <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 20px; -fx-font-weight: 700; -fx-background-color: #edd6d8; -fx-padding: 8 0 0 16;" text="Shopping Cart" BorderPane.alignment="TOP_LEFT">
                    <BorderPane.margin>
                        <Insets left="6.0" top="6.0" />
                    </BorderPane.margin>
                </Label>
            </top>

            <bottom>
                <HBox alignment="CENTER_LEFT" spacing="180.0" BorderPane.alignment="CENTER">
                    <children>
                        <Label style="-fx-text-fill: #8e5f5f; -fx-font-size: 24px; -fx-font-weight: 700;" text="Cart Summary:" />
                        <VBox spacing="10.0">
                            <children>
                                <Label fx:id="lblSubtotal" style="-fx-text-fill: #8e5f5f; -fx-font-size: 22px;" text="Subtotal: $0" />
                                <Label fx:id="lblShipping" style="-fx-text-fill: #8e5f5f; -fx-font-size: 22px;" text="Shipping: $0" />
                                <Label fx:id="lblTotal" style="-fx-text-fill: #8e5f5f; -fx-font-size: 22px;" text="Total: $0" />
                            </children>
                        </VBox>
                        <Button onAction="#goCheckout" prefHeight="48.0" prefWidth="180.0" style="-fx-background-color: #f59bc0; -fx-text-fill: #8e5f5f; -fx-font-size: 24px; -fx-background-radius: 6;" text="Checkout" />
                    </children>
                </HBox>
            </bottom>

            <center>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <content>
                        <VBox fx:id="cartItemsContainer" spacing="10.0" BorderPane.alignment="CENTER">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="36.0" style="-fx-background-color: #f7c8d7;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 13px;" text="Flower Shop. flowershop@gmail.com" />
            </children>
        </HBox>
    </bottom>

</BorderPane>