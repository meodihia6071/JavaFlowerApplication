<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f8eef1;" stylesheets="@../css/user-style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="flowershop.controllers.ProfileController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="56.0" spacing="22.0" styleClass="top-bar">
            <padding>
                <Insets left="18.0" right="18.0" />
            </padding>
            <children>
                <Label style="-fx-font-weight: 700; -fx-font-size: 27px;" styleClass="brand-label" text="Flower shop" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#goHome" styleClass="nav-button" text="Home" />
                <Button onAction="#goFlowers" styleClass="nav-button" text="Flowers" />
                <Button onAction="#goCategories" styleClass="nav-button" text="Categories" />
                <Button onAction="#goContact" styleClass="nav-button" text="Contact" />
                <Button fx:id="btnCart" onAction="#goCart" styleClass="nav-button" text="Cart" />
                <Button fx:id="btnProfile" onAction="#goProfile" prefHeight="42.0" prefWidth="42.0" styleClass="nav-button-active">
                    <graphic>
                        <ImageView fitHeight="22.0" fitWidth="22.0" preserveRatio="true">
                            <image>
                                <Image url="@../images/user-icon.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                <Button onAction="#handleLogout" prefHeight="34.0" prefWidth="94.0" styleClass="logout-button" text="Log Out" />
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f8eef1;">
            <content>
                <VBox alignment="TOP_CENTER" spacing="25.0" style="-fx-padding: 30 60 30 60;">
                    <children>
                        <VBox alignment="CENTER" spacing="10.0">
                            <ImageView fitHeight="80.0" fitWidth="80.0" preserveRatio="true">
                                <image>
                                    <Image url="@../images/user-icon.png" />
                                </image>
                            </ImageView>
                            <Label fx:id="lblDisplayName" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #8e5f5f;" text="Họ và Tên" />
                        </VBox>

                        <HBox spacing="25.0" alignment="TOP_CENTER">
                            <children>
                                <VBox spacing="20.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: #f3c6d4; -fx-border-radius: 15;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #8e5f5f;" text="Thông tin cá nhân" />
                                        <GridPane hgap="15.0" vgap="15.0">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="100.0" prefWidth="120.0" />
                                                <ColumnConstraints hgrow="ALWAYS" />
                                            </columnConstraints>
                                            <children>
                                                <Label text="Username:" GridPane.rowIndex="0" />
                                                <TextField fx:id="txtUsername" editable="false" style="-fx-background-color: #eee;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                                <Label text="Họ tên:" GridPane.rowIndex="1" />
                                                <TextField fx:id="txtFullName" styleClass="profile-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                                <Label text="Email:" GridPane.rowIndex="2" />
                                                <TextField fx:id="txtEmail" styleClass="profile-input" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                                <Label text="Số điện thoại:" GridPane.rowIndex="3" />
                                                <TextField fx:id="txtPhone" styleClass="profile-input" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                            </children>
                                        </GridPane>
                                        <Button onAction="#handleUpdateInfo" maxWidth="Infinity" styleClass="primary-button" text="LƯU THÔNG TIN" />
                                    </children>
                                </VBox>

                                <VBox spacing="20.0" prefWidth="380.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: #f3c6d4; -fx-border-radius: 15;">
                                    <children>
                                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #8e5f5f;" text="Bảo mật" />
                                        <VBox spacing="10.0">
                                            <Label text="Mật khẩu mới" />
                                            <StackPane alignment="CENTER_RIGHT">
                                                <PasswordField fx:id="txtNewPassword" styleClass="profile-input" />
                                                <TextField fx:id="txtNewPasswordVisible" visible="false" styleClass="profile-input" />
                                                <Button onAction="#toggleNewPassword" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                                    <graphic>
                                                        <ImageView fitHeight="18.0" fitWidth="18.0" opacity="0.5" preserveRatio="true">
                                                            <image>
                                                                <Image url="@../images/eye-icon.png" />
                                                            </image>
                                                        </ImageView>
                                                    </graphic>
                                                </Button>
                                            </StackPane>

                                            <Label text="Xác nhận mật khẩu" />
                                            <StackPane alignment="CENTER_RIGHT">
                                                <PasswordField fx:id="txtConfirmPassword" styleClass="profile-input" />
                                                <TextField fx:id="txtConfirmPasswordVisible" visible="false" styleClass="profile-input" />
                                                <Button onAction="#toggleConfirmPassword" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                                    <graphic>
                                                        <ImageView fitHeight="18.0" fitWidth="18.0" opacity="0.5" preserveRatio="true">
                                                            <image>
                                                                <Image url="@../images/eye-icon.png" />
                                                            </image>
                                                        </ImageView>
                                                    </graphic>
                                                </Button>
                                            </StackPane>
                                        </VBox>
                                        <Button onAction="#handleChangePassword" maxWidth="Infinity" styleClass="primary-button" text="ĐỔI MẬT KHẨU" />
                                        <Button onAction="#showDeliveryHistory" maxWidth="Infinity" style="-fx-background-color: #f3dfe3; -fx-text-fill: #8e5f5f;" text="XEM LỊCH SỬ MUA HÀNG" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox fx:id="paneHistory" managed="false" visible="false" spacing="15.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: #f3c6d4; -fx-border-radius: 15;">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #8e5f5f;" text="Lịch sử giao hàng" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#hideHistory" text="Đóng" style="-fx-background-color: transparent; -fx-text-fill: red;" />
                                </HBox>
                                <TableView fx:id="tableHistory" prefHeight="300.0">
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>

                                    <columns>
                                        <TableColumn fx:id="colId" text="Mã Đơn" />
                                        <TableColumn fx:id="colDate" text="Ngày Đặt" />
                                        <TableColumn fx:id="colPointsUsed" text="Chiết khấu" />
                                        <TableColumn fx:id="colTotal" text="Tổng Tiền" />
                                        <TableColumn fx:id="colPointsEarned" text="Số điểm nhận được" />
                                        <TableColumn fx:id="colStatus" text="Trạng Thái" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="36.0" style="-fx-background-color: #f7c8d7;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 13px;" text="Flower Shop. flowershop@gmail.com" />
            </children>
        </HBox>
    </bottom>
</BorderPane>