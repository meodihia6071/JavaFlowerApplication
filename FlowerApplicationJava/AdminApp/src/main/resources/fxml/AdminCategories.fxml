<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="700" prefWidth="1200"
      stylesheets="@../css/admin-style.css"
      styleClass="main-bg"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="flowershop.controllers.AdminCategoriesController">

    <children>

        <VBox styleClass="sidebar">
            <children>
                <Label text="🌷 Flower Shop" styleClass="logo"/>

                <Separator prefWidth="210" styleClass="sidebar-separator">
                    <VBox.margin>
                        <Insets left="20" right="20" bottom="10"/>
                    </VBox.margin>
                </Separator>

                <Button text="🏠  Dashboard" onAction="#goDashboard" styleClass="menu-btn"/>
                <Button text="🌸  Products" onAction="#goProducts" styleClass="menu-btn"/>

                <Button text="📂  Categories"
                        styleClass="menu-btn"
                        style="
                            -fx-background-color:white;
                            -fx-text-fill:#e25a84;
                            -fx-font-weight:bold;
                            -fx-pref-width:250;
                            -fx-alignment:CENTER_LEFT;
                            -fx-padding:15 0 15 34;
                            -fx-border-width:0 0 0 6;
                            -fx-border-color:#e25a84;
                        "/>

                <Button text="📦  Orders" onAction="#goOrders" styleClass="menu-btn"/>
                <Button text="👤  Customers" onAction="#goCustomers" styleClass="menu-btn"/>
                <Button text="🚚  Suppliers" onAction="#goSuppliers" styleClass="menu-btn"/>
                <Button text="📦  Stock" onAction="#goStock" styleClass="menu-btn"/>
                <Button text="👔  Employees" onAction="#goUserManage" styleClass="menu-btn"/>
                <Button text="📈  Reports" onAction="#goReports" styleClass="menu-btn"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER">
                    <padding>
                        <Insets top="20" bottom="30"/>
                    </padding>
                    <Button text="⏻ Log Out" onAction="#handleLogout" styleClass="logout-btn"/>
                </HBox>
            </children>
        </VBox>

        <HBox spacing="20" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <children>
                <VBox spacing="15" HBox.hgrow="ALWAYS">
                    <children>

                        <Label text="Categories" styleClass="page-title"/>

                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                            <children>
                                <Button mnemonicParsing="false" styleClass="tool-btn" text="+ Add Category" />
                                <Region HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                        <TableView VBox.vgrow="ALWAYS" styleClass="table-view">
                            <columns>
                                <TableColumn prefWidth="100.0" text="ID" styleClass="center-column" />
                                <TableColumn prefWidth="400.0" text="Category Name" styleClass="left-column" />
                                <TableColumn prefWidth="150.0" text="Action" styleClass="center-column" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                    </children>
                </VBox>
            </children>
        </HBox>

    </children>
</HBox>